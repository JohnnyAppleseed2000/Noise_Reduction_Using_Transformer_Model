    <annotation encoding="application/x-tex">{\displaystyle O(TF)}</annotation>
  </semantics>
</math></span><img src="https://wikimedia.org/api/rest_v1/media/math/render/svg/a5bfde97a10971e8fa6a0179a064d2723e49e0b1" class="mwe-math-fallback-image-inline mw-invert skin-invert" aria-hidden="true" style="vertical-align: -0.838ex; width:6.96ex; height:2.843ex;" alt="{\displaystyle O(TF)}"></span>
</td></tr>
