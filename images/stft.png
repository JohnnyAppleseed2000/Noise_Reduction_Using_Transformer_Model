<div class="mw-heading mw-heading3"><h3 id="Recursive_method">Recursive method</h3><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Short-time_Fourier_transform&amp;action=edit&amp;section=17" title="Edit section: Recursive method"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
<div class="mw-heading mw-heading4"><h4 id="Constraint_2">Constraint</h4><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Short-time_Fourier_transform&amp;action=edit&amp;section=18" title="Edit section: Constraint"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
<p>a. <span class="mwe-math-element mwe-math-element-inline"><span class="mwe-math-mathml-inline mwe-math-mathml-a11y" style="display: none;"><math xmlns="http://www.w3.org/1998/Math/MathML"  alttext="{\displaystyle \Delta _{t}\Delta _{f}={\tfrac {1}{N}}}">
