<div class="mw-heading mw-heading3"><h3 id="Direct_implementation">Direct implementation</h3><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Short-time_Fourier_transform&amp;action=edit&amp;section=13" title="Edit section: Direct implementation"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
<div class="mw-heading mw-heading4"><h4 id="Constraints">Constraints</h4><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Short-time_Fourier_transform&amp;action=edit&amp;section=14" title="Edit section: Constraints"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
